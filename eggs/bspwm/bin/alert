#!/bin/sh

BAT_PATH="/sys/class/power_supply"
THRESHOLD=20
notified=0

# Get the battery path
get_battery() {
    for bat in "$BAT_PATH"/BAT*; do
        [ -d "$bat" ] && echo "$bat" && return
    done
}

# Subscribe to battery events
while true; do
    bat=$(get_battery)
    [ -z "$bat" ] && sleep 60 && continue

    capacity=$(cat "$bat/capacity")
    status=$(cat "$bat/status")

    # If battery low and not charging, notify once
    if [ "$capacity" -le "$THRESHOLD" ] && [ "$status" != "Charging" ]; then
        if [ "$notified" -eq 0 ]; then
            ( herbe "Battery Low" "Battery at ${capacity}%" -u critical -i battery-caution )
            notified=1
        fi
    else
        # Reset notifier
        notified=0
    fi

    sleep 60
done
