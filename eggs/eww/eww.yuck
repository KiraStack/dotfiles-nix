; Variables
(defvar debug 0)
; (defvar eww "eww -c ~/.config/eww/")

; Polls
(defpoll date :interval "1m" "date +%d/%m")
(defpoll time :interval "1m" "date +%H:%M")

; Listeners
(deflisten battery "scripts/battery")
(deflisten microphone "scripts/microphone")
(deflisten network "scripts/network")
(deflisten speakers "scripts/speakers")
(deflisten workspaces "scripts/workspaces")

; Packages
(include "license/eww.yuck")
(include "bar/eww.yuck")
