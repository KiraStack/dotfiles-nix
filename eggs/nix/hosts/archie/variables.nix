{
  # User
  username = "archie";

  # Programs
  desktop = "bspwm"; # must be 'bspwm'
  terminal = "st"; # must be 'st'
  editor =
    "neovim"; # can be 'vscode' or 'neovim' (does not make a difference, tbh)
  browser = "firefox"; # must be 'firefox'
  shell = "bash"; # can be 'bash' or 'fish'

  # Hardware
  videoDriver = "amdgpu"; # can be 'nvidia', 'amdgpu', or 'intel'
  bluetoothSupport = true;

  # Localization
  timezone = "Europe/London";
  locale = "en_GB.UTF-8";
  clock24h = true;
  kbdLayout = "gb";
  kbdVariant = "extd";
  consoleKeymap = "uk";
}
