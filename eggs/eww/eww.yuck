; Constants
(defvar debug 0)

; Queries
(defpoll date :interval "1m" "date +%d/%m")

; Listeners
(deflisten workspaces "bin/workspaces")
(deflisten speakers "bin/speakers")
(deflisten battery "bin/battery")
(deflisten network "bin/network")
(deflisten microphone "bin/microphone")

; Headers
(include "bar/eww.yuck")
