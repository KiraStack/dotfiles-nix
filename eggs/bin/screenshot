#!/bin/sh

# Directory to save screenshots
DIR="$HOME/Pictures/Screenshots"
mkdir -p "$DIR"

# Timestamped filename
TIMESTAMP=$(date +'%Y-%m-%d_%H-%M-%S')
FILE="$DIR/$TIMESTAMP.png"

# Check for optional argument "select" to capture region
if [ "$1" = "select" ]; then
    GEOMETRY=$(slop)
    if [ -z "$GEOMETRY" ]; then
        echo "No region selected."
        exit 1
    fi
    maim -g "$GEOMETRY" "$FILE"
else
    # Fullscreen capture
    maim "$FILE"
fi

# Verify screenshot was created
if [ ! -f "$FILE" ]; then
    echo "Failed to take screenshot."
    exit 1
fi

# Copy to clipboard
if command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard -t image/png -i "$FILE"
fi

# Send notification
if command -v dunstify >/dev/null 2>&1; then
    dunstify -u normal -t 3000 -i info "Screenshot saved: $FILE"
fi
