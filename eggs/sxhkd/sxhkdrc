# Open terminal
super + Return
  $TERMINAL

# Open default browser
super + b
  $BROWSER

# Open file manager
super + n
    $TERMINAL -e lf

# Program Launcher
super + space
  rofi -show drun

# Clipboard menu via rofi (X11)
super + v
  tac "$HOME/.cache/clipboard.txt" 2>/dev/null | awk '!seen[$0]++' | rofi -dmenu -i -p "Clipboard" | xclip -selection clipboards

# Clear clipboard history
super + shift + v
  (> "$HOME/.cache/clipboard.txt" && command -v herbe >/dev/null && (herbe "Clipboard history cleared" & pid=$!; (sleep 1 && kill "$pid" 2>/dev/null) &))

# Screenshot
super + p
  screenshot
super + shift + p
  screenshot selectq233

# Focus
super + {h,j,k,l}
  bspc node -f {west,south,north,east}

# Move windows
super + shift + {h,j,k,l}
  bspc node -m {west,south,north,east}

# Toggle state
super + f
  bspc node -t ~floating
super + g
  bspc node -t ~fullscreen

# Switch desktops
super + {1-9}
  bspc desktop -f ^{1-9}

# Switch and move focused node
super + shift + 1
  bspc node -d ^1 && bspc desktop -f ^1

# Switch and move focused node
super + shift + 2
  bspc node -d ^2 && bspc desktop -f ^2

# Switch and move focused node
super + shift + 3
  bspc node -d ^3 && bspc desktop -f ^3

# Switch and move focused node
super + shift + 4
  bspc node -d ^4 && bspc desktop -f ^4

# Switch and move focused node
super + shift + 5
  bspc node -d ^5 && bspc desktop -f ^5

# Switch and move focused node
super + shift + 6
  bspc node -d ^6 && bspc desktop -f ^6

# Switch and move focused node
super + shift + 7
  bspc node -d ^7 && bspc desktop -f ^7

# Switch and move focused node
super + shift + 8
  bspc node -d ^8 && bspc desktop -f ^8

# Switch and move focused node
super + shift + 9
  bspc node -d ^9 && bspc desktop -f ^9

# Close window
super + q
  bspc node -c

# Brightness management
XF86MonBrightnessUp
  brightness change up
XF86MonBrightnessDown
  brightness change down

# Media controls
XF86AudioPlay
  playerctl play-pause
XF86AudioNext
  playerctl next
XF86AudioPrev
  playerctl previous

# Volume management
XF86AudioRaiseVolume
  volume change up
XF86AudioLowerVolume
  volume change down
XF86AudioMute
  volume -D pulse sset Master toggle-mute

# Restart bspwm
super + alt + w
  bspc wm -r
